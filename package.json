{
  "name": "accutime",
  "version": "2.0.0",
  "description": "A JS library that fetches time using NTP's algorithm and WS and returns the time.",
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm,iife --globalName AccuTime --minify --dts --clean",
    "prepublishOnly": "npm run build"
  },
  "author": "@uimaxbai",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "browser": "./dist/index.global.js",
  "unpkg": "./dist/index.global.js",
  "jsdelivr": "./dist/index.global.js",
  "types": "./dist/index.d.ts",
  "license": "MIT",
  "devDependencies": {
    "@swc/core": "^1.15.21",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "terser-webpack-plugin": "^5.3.10"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  }
}
